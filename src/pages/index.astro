---
import Contact from "@/components/Contact.astro"
import Education from "@/components/Education.astro"
import Experience from "@/components/Experience.astro"
import Header from "@/components/Header.astro"
import Projects from "@/components/Projects.astro"
import Section from "@/components/Section.astro"
import Skills from "@/components/Skills.astro"
import resume from "@/data/resume.json"
import Layout from "@/layouts/Layout.astro"

const { basics, work, skills, education, projects } = resume

const projectGallery = [
  { name: "Clock", url: "/projects/Relogio-en/relogio.html" },
  { name: "Stopwatch", url: "/projects/Cronometro-en/cronometro.html" },
  { name: "Lamp", url: "/projects/Lampada-en/lampada.html" },
  { name: "BMI Calculator", url: "/projects/Calculadora_de_imc-en/calculadora.html" },
]
---

<Layout title={`${basics.name} - ${basics.label}`} description={basics.summary} lang="en">
  <Header basics={basics} currentUrl="/" otherLang="/pt" langLabel="PT" />

  <Section title="About">
    <p class="text-slate-700 dark:text-slate-300 leading-relaxed mb-4">
      {basics.summary}
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {projectGallery.map((project) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="block p-3 bg-slate-50 dark:bg-slate-800 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors text-center"
        >
          <span class="text-sm font-medium text-slate-700 dark:text-slate-300">{project.name}</span>
        </a>
      ))}
    </div>
  </Section>

  <Section title="Experience">
    <Experience work={work} />
  </Section>

  <Section title="Skills">
    <Skills skills={skills} />
  </Section>

  <Section title="Education">
    <Education education={education} />
  </Section>

  <Section title="Projects">
    <Projects projects={projects} />
  </Section>

  <Section title="Contact">
    <Contact basics={basics} />
  </Section>
</Layout>